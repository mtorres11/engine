<Actions>
<!--Hotkeys-->
  <action name="Logger">
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_DOWN"  Code="KEY_LCTRL"/>
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_DOWN_UP"  Code="KEY_F1"/>
  </action>

  <action name="Console">
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_DOWN_UP"  Code="KEY_F2"/>
  </action>

  <action name="ProcessInfo">
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_DOWN"  Code="KEY_LCTRL"/>
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_DOWN"  Code="KEY_F3"/>
  </action>
  
  <action name="Screenshot">
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_DOWN_UP"  Code="KEY_F4"/>
  </action>

  <action name="SaveLogsInFile">
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_DOWN_UP"  Code="KEY_F5"/>
  </action>

  <action name="ReloadTTFs">
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_DOWN_UP"  Code="KEY_F6"/>
  </action>

  <action name="ReloadLanguageXMLs">
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_DOWN_UP"  Code="KEY_F7"/>
  </action>

  <action name="ReloadActions">
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_DOWN_UP"  Code="KEY_F8"/>
  </action>
  
  <action name="ReloadLua">
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_DOWN_UP"  Code="KEY_F9"/>
  </action>

   <action name="ReloadRenderableObjects">
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_DOWN_UP"  Code="KEY_R"/>
  </action>
  
   <action name="ReloadEffects">
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_DOWN_UP"  Code="KEY_E"/>
   </action>

  <action name="LogRender_PageDown">
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_UP_DOWN"  Code="KEY_PGDOWN"/>
  </action>

  <action name="LogRender_PageUp">
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_UP_DOWN"  Code="KEY_PGUP"/>
  </action>

  <action name="LogRender_PrevLine">
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_DOWN"     Code="KEY_LCTRL"/>
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_UP_DOWN"  Code="KEY_UP"/>
  </action>

  <action name="LogRender_NextLine">
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_DOWN"     Code="KEY_LCTRL"/>
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_UP_DOWN"  Code="KEY_DOWN"/>
  </action>
  
<!--Movement-->
  <action name="GoForward">
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_DOWN"  Code="KEY_W"/>
  </action>
  <action name="GoBackwards">
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_DOWN"  Code="KEY_S"/>
  </action>
  <action name="GoSidewardLeft">
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_DOWN"  Code="KEY_A"/>
  </action>
  <action name="GoSidewardRight">
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_DOWN"  Code="KEY_D"/>
  </action>
  <action name="GoUp">
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_DOWN"  Code="KEY_R"/>
  </action>
  <action name="GoDown">
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_DOWN"  Code="KEY_F"/>
  </action>
  <action name="PlayerRun">
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_DOWN"  Code="KEY_LSHIFT"/>
  </action>
  <action name="PlayerQuiet">
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_DOWN"  Code="KEY_LCTRL"/>
  </action>
  <action name="PlayerNormalSpeed">
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_DOWN_UP"  Code="KEY_LCTRL"/>
  </action>
  
  <!--Reload Actions-->
  <action name="ReloadRenderableObjects">
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_DOWN"     Code="KEY_LCTRL"/>
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_UP_DOWN"  Code="KEY_L"/>
  </action>
  
  <!--Print Screen in file-->
  <action name="PrintScreen">
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_DOWN"     Code="KEY_LWIN"/>
    <input deviceType="IDV_KEYBOARD" EventType="EVENT_UP_DOWN"  Code="KEY_P"/>
  </action>

